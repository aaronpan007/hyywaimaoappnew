# ============================================
# Waimao Toolkit - Environment Variables
# ============================================
# Copy this file to your project root as .env
# and fill in your actual API keys.

# --- Customer Acquisition (搜索客户) ---
# Google 搜索 API，搜索目标公司。从 https://serper.dev 免费获取（2500次/月）
SERPER_API_KEY=your_serper_api_key_here

# --- AI Analysis & Email Generation (AI分析 + 生成开发信) ---
# AI 模型调用，分析匹配度 + 生成开发信。从 https://replicate.com/account/api-tokens 获取
REPLICATE_API_TOKEN=your_replicate_api_token_here

# --- Email Blast (发送邮件) ---
# 邮件发送 API。从 https://resend.com/api-keys 获取（Sending access 权限）
RESEND_API_KEY=your_resend_api_key_here
# 发件人邮箱。域名须在 Resend 完成 DNS 验证。格式：品牌名 <前缀@域名>
FROM_EMAIL=Brand Name <sales@yourdomain.com>
# 客户回复接收地址（可选）
REPLY_TO_EMAIL=your_reply_email@gmail.com
