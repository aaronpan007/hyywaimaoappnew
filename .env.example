# ============================================================
# hyyskill 环境变量配置
# 复制本文件为 .env 并填入实际值
# ============================================================

# --- 阶段 A：初始配置（搜索/分析/生成） ---
# Google 搜索 API，搜索目标公司。从 https://serper.dev 免费获取（2500次/月）
SERPER_API_KEY=your_serper_api_key_here

# AI 模型调用，分析匹配度 + 生成开发信。从 https://replicate.com/account/api-tokens 获取
REPLICATE_API_TOKEN=your_replicate_api_token_here
# Test default: cheaper/faster. Change to openai/gpt-5.2 for production-quality runs.
REPLICATE_MODEL=openai/gpt-4.1-nano

# --- 阶段 B：发送前配置（邮件发送） ---
# 邮件发送 API。从 https://resend.com/api-keys 获取（Sending access 权限）。详见 email-blast/references/resend-guide.md
RESEND_API_KEY=your_resend_api_key_here

# Resend Webhook 签名密钥。用于接收 delivered/bounced/failed/complained 等回调事件
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# Better Auth session signing secret. Use the same value in frontend and backend env.
BETTER_AUTH_SECRET=your_better_auth_secret_here
# Production only when frontend and backend share clientconnet.com subdomains.
# Example: .clientconnet.com lets clientconnet.com and api.clientconnet.com share auth cookies.
BETTER_AUTH_COOKIE_DOMAIN=.clientconnet.com

# 发件人邮箱。域名须在 Resend 完成 DNS 验证。可在首次发送前再配置，不阻塞搜索/分析
# 格式：品牌名 <前缀@域名>，如 "PRANCE Building <sales@nongtehub.com>"
FROM_EMAIL=Brand Name <sales@clientconnet.com>
MAIL_DOMAIN=clientconnet.com

# 客户回复接收地址。未设置则发到 FROM_EMAIL（可选）
REPLY_TO_EMAIL=your_reply_email@gmail.com

# --- 飞书（无需配置） ---
# 飞书认证通过 lark-cli 全局管理，无需在 .env 中配置
# 表格引用通过各 skill 的 config.json 管理
# 运行 python run.py --get-auth-url 获取授权链接
